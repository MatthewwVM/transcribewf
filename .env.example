# Transcription Workflow Configuration
# Copy this file to .env and customize for your setup:
#   cp .env.example .env
#
# ============================================
# Quick Start Configurations
# ============================================
#
# BASIC SETUP (Fastest, no speaker labels, CPU-only):
#   USE_WHISPERX=false
#   WHISPER_MODEL=tiny
#   OLLAMA_MODEL=llama2
#   ENABLE_OLLAMA=true
#
# RECOMMENDED SETUP (Speaker labels, GPU-accelerated, good quality):
#   USE_WHISPERX=true
#   ENABLE_SPEAKER_DIARIZATION=true
#   WHISPER_MODEL=tiny          # Fast with GPU (use base/small for better accuracy)
#   OLLAMA_MODEL=qwen2.5:14b    # Best for structured notes
#   HUGGINGFACE_TOKEN=hf_your_token_here
#   ENABLE_OLLAMA=true
#
# HIGH QUALITY (Best accuracy, slower):
#   USE_WHISPERX=true
#   ENABLE_SPEAKER_DIARIZATION=true
#   WHISPER_MODEL=small         # Or medium/large for best accuracy
#   OLLAMA_MODEL=mixtral:8x7b
#   HUGGINGFACE_TOKEN=hf_your_token_here
#   ENABLE_OLLAMA=true
#
# ============================================

# ============================================
# NFS/Network Storage Configuration
# ============================================

# NFS server address and path
# Format: server:path (no leading slash before path for NFS)
# Example for Synology: 10.0.0.136:volume1/NFS/rotation
NFS_SERVER=10.0.0.136:volume1/NFS/rotation

# Local mount point where NFS share will be mounted
MOUNT_POINT=/mnt/rotation

# Directory containing audio files to transcribe (relative to mount point)
# The script will look for audio files in: MOUNT_POINT/SOURCE_FOLDER
SOURCE_FOLDER=totranscribe

# Directory where transcribed files will be saved (relative to mount point)
# Results will be saved to: MOUNT_POINT/DEST_FOLDER
DEST_FOLDER=transcribed

# ============================================
# Whisper/WhisperX Configuration
# ============================================

# Whisper model size to use for transcription
# Options: tiny, base, small, medium, large
# Larger models are more accurate but slower and require more memory
#
# GPU Performance (RTX 3080 Ti, float16):
#   - tiny: ~4-5 min for 60min audio, excellent speed/quality balance
#   - base: ~6-8 min for 60min audio, better accuracy
#   - small: ~10-15 min for 60min audio, high accuracy
#
# CPU Performance (slower, use int8):
#   - tiny: ~6-8 min for 60min audio
#   - base: ~10-15 min for 60min audio
#   - small: ~20-30 min for 60min audio
#
# Recommended: Start with 'tiny' - it's surprisingly accurate with GPU acceleration
WHISPER_MODEL=tiny

# ============================================
# WhisperX Speaker Diarization (Optional)
# ============================================

# Use WhisperX for enhanced transcription (true/false)
# Benefits:
#   ✓ Better word-level timestamps
#   ✓ Speaker identification (who said what)
#   ✓ Improved note quality (Ollama can distinguish speakers)
#   ✓ GPU acceleration (auto-detects CUDA, uses float16)
# Drawbacks:
#   ✗ Slower processing (~2-3x vanilla Whisper without GPU)
#   ✗ Requires HuggingFace token for speaker diarization
#
# Recommended: Set to 'true' for best results
USE_WHISPERX=true

# Enable speaker diarization to identify different speakers (true/false)
# When enabled, transcripts will include speaker labels like:
#   [SPEAKER_00]: Hey everyone, thanks for joining.
#   [SPEAKER_01]: Thanks Matt, we're looking at FlashArray...
#
# Requirements:
#   - USE_WHISPERX must be true
#   - HUGGINGFACE_TOKEN must be set
#   - First run downloads ~100MB model (cached locally after)
#   - Must accept user agreement: https://huggingface.co/pyannote/speaker-diarization-3.1
#
# Performance impact:
#   - GPU: Adds ~5-10 min for 60min audio
#   - CPU: Adds ~15-30 min for 60min audio
#
# Worth it for: Multi-person calls where identifying speakers matters
# Recommended: Set to 'true' for customer calls
ENABLE_SPEAKER_DIARIZATION=true

# HuggingFace API token for speaker diarization
#
# Setup (one-time, free):
#   1. Create account: https://huggingface.co/join
#   2. Accept agreement: https://huggingface.co/pyannote/speaker-diarization
#      (Click "Agree and access repository")
#   3. Get token: https://huggingface.co/settings/tokens
#      (Click "New token", select "Read" access)
#   4. Paste token below (format: hf_xxxxxxxxxxxxxxxxxxxxx)
#
# Note: Token is only used to download the model on first run.
#       After that, the model runs locally (no internet needed).
HUGGINGFACE_TOKEN=your_token_here

# ============================================
# Ollama Configuration
# ============================================

# Ollama model to use for generating markdown notes from transcriptions
#
# Recommended models (install with: ollama pull <model_name>):
#   - qwen2.5:14b    - ⭐ BEST for structured output, follows instructions well
#   - llama3:8b      - Good balance of speed and quality
#   - mixtral:8x7b   - Best quality for technical content (slower)
#   - mistral:7b     - Fast, good for simple notes
#   - llama2:7b      - Basic option
#
# For best results with speaker-labeled transcripts, use qwen2.5:14b
# Note generation typically takes 15-30 seconds regardless of model
OLLAMA_MODEL=qwen2.5:14b

# ============================================
# Logging Configuration
# ============================================

# Path to log file
# Note: The user running the script needs write permissions
LOG_FILE=/var/log/transcribe_workflow.log

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ============================================
# Advanced Options (Optional)
# ============================================

# Supported audio file extensions (comma-separated, no spaces)
# AUDIO_EXTENSIONS=mp3,wav,m4a,flac,ogg,opus,aac

# Maximum number of files to process in one run (0 = unlimited)
# MAX_FILES_PER_RUN=0

# Enable/disable Ollama markdown generation (true/false)
# Set to false if you only want transcription without AI-generated notes
# When enabled, generates structured markdown notes from transcripts
# Output includes both AI-generated notes AND full transcript appended at the end
ENABLE_OLLAMA=true

# ============================================
# Ollama Prompt Template (Optional)
# ============================================

# Custom prompt template for Ollama note generation
# Available placeholders:
#   {audio_filename}      - Name of the audio file being transcribed
#   {transcription_text}  - Full transcript with speaker labels (if enabled)
#   {has_speakers}        - "true" if speaker diarization is enabled, "false" otherwise
#
# Customize this prompt to match your note-taking needs!
# Leave empty to use a basic built-in fallback prompt.
#
OLLAMA_PROMPT_TEMPLATE="You are an expert meeting note taker.

Create structured notes from this conversation with the following sections:

## Attendees
[List all participants]

## Summary
[Brief overview of the meeting purpose and outcomes]

## Key Discussion Points
- [Main topics discussed]
- [Important details and context]

## Decisions Made
- [Key decisions and rationale]

## Action Items
- [ ] [Owner]: [Task description] - [Deadline]

## Technical Details
- [Any technical specifications, numbers, or configurations mentioned]

Audio file: {audio_filename}

Transcript:
{transcription_text}

Generate comprehensive, well-organized notes in markdown format."

